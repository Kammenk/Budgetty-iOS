    "Tap to show or hide a section. Use Edit to drag and reorder. Applies on iPhone." : {
      "comment" : "A description of the Home customization sheet.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Докоснете, за да покажете или скриете секция. Използвайте Редактиране, за да пренаредите. Важи за iPhone."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Klepnutím zobrazíte nebo skryjete sekci. Pomocí Upravit změníte pořadí. Platí na iPhonu."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
