    "Bills are planned — not yet spent." : {
      "comment" : "A description of the \"planned\" bills that aren't yet spent.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сметките са планирани — още не са платени."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Účty jsou plánované — zatím nezaplacené."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regninger er planlagt — endnu ikke brugt."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rechnungen sind geplant — noch nicht ausgegeben."
          }
        },
