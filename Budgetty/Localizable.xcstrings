    "Insights are tailored to you — they'll fill in as you add your first receipts." : {
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Анализ е съобразен с вас — ще се попълва, докато добавяте първите си бележки."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přehledy jsou přizpůsobeny vám — vyplní se, jakmile přidáte první účtenky."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Indsigt er tilpasset til dig — den fyldes ud, når du tilføjer dine første kvitteringer."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine Einblicke sind auf dich zugeschnitten — sie füllen sich, sobald du deine ersten Belege hinzufügst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los Análisis se adaptan a ti — se irán completando a medida que añadas tus primeros recibos."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Analyysi on räätälöity sinulle — se täyttyy sitä mukaa kun lisäät ensimmäiset kuittisi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tes Analyses sont personnalisées — elles se rempliront au fur et à mesure que tu ajoutes tes premiers reçus."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le Analisi sono personalizzate per te — si popoleranno man mano che aggiungi i tuoi primi scontrini."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Innsikt er tilpasset deg — den fylles ut etter hvert som du legger til dine første kvitteringer."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Inzichten zijn op jou afgestemd — ze vullen zich naarmate je je eerste bonnen toevoegt."
