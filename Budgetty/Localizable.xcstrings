    "Merge keeps your current data and adds the backup. Replace deletes everything first." : {
      "comment" : "A message displayed in a confirmation dialog when importing a backup.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сливането запазва текущите данни и добавя копието. Замяната първо изтрива всичко."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sloučení zachová aktuální data a přidá zálohu. Nahrazení nejprve vše smaže."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fletning beholder dine data og tilføjer sikkerhedskopien. Erstat sletter alt først."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zusammenführen behält deine Daten und fügt das Backup hinzu. Ersetzen löscht zuerst alles."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Combinar mantiene tus datos y añade la copia. Reemplazar borra todo primero."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yhdistäminen säilyttää nykyiset tiedot ja lisää varmuuskopion. Korvaaminen poistaa ensin kaiken."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fusion conserve vos données et ajoute la sauvegarde. Remplacer efface tout d’abord."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unisci mantiene i dati attuali e aggiunge il backup. Sostituisci cancella prima tutto."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
