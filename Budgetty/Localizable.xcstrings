    "Free widget slots are full. Remove one from your home screen, or upgrade for unlimited widgets." : {
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Безплатните слотове за джаджи са запълнени. Премахни една от началния екран или надгради за неограничени джаджи."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bezplatné sloty pro widgety jsou plné. Odeberte jeden z domovské obrazovky nebo upgradujte pro neomezené widgety."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De gratis widgetpladser er fyldt. Fjern en fra startskærmen, eller opgrader for ubegrænsede widgets."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die kostenlosen Widget-Plätze sind belegt. Entferne eines vom Startbildschirm oder mach ein Upgrade für unbegrenzte Widgets."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los espacios de widget gratis están llenos. Quita uno de la pantalla de inicio o mejora para tener widgets ilimitados."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ilmaiset widget-paikat ovat täynnä. Poista yksi aloitusnäytöltä tai päivitä saadaksesi rajattomat widgetit."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les emplacements de widget gratuits sont pleins. Retirez-en un de l'écran d'accueil ou passez à Premium pour des widgets illimités."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli slot widget gratuiti sono esauriti. Rimuovine uno dalla schermata Home o passa a Premium per widget illimitati."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De gratis widgetplassene er fulle. Fjern en fra startskjermen, eller oppgrader for ubegrensede widgets."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De gratis widgetplekken zijn vol. Verwijder er een van het startscherm of upgrade voor onbeperkt widgets."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Darmowe miejsca na widżety są zajęte. Usuń jeden z ekranu głównego lub ulepsz plan, aby mieć nielimitowane widżety."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os espaços de widget gratuitos estão cheios. Remova um da tela inicial ou faça upgrade para widgets ilimitados."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sloturile gratuite pentru widgeturi sunt pline. Elimină unul de pe ecranul principal sau fă upgrade pentru widgeturi nelimitate."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Бесплатные слоты для виджетов заняты. Удалите один с главного экрана или оформите подписку для безлимитных виджетов."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De gratis widgetplatserna är fulla. Ta bort en från hemskärmen eller uppgradera för obegränsade widgetar."
          }
        }
      }
    },
