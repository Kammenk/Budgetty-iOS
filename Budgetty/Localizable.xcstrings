    "Go Premium to scan more — manual entry is always free." : {
      "comment" : "A description of the benefits of Premium.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вземете Premium за повече сканирания — ръчното въвеждане е винаги безплатно."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Získejte Premium pro více skenů — ruční zadání je vždy zdarma."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Få Premium for at scanne mere — manuel indtastning er altid gratis."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hol dir Premium für mehr Scans — manuelle Eingabe ist immer kostenlos."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hazte Premium para escanear más; la entrada manual siempre es gratis."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hanki Premium skannataksesi enemmän — manuaalinen syöttö on aina ilmaista."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passez à Premium pour scanner plus — la saisie manuelle est toujours gratuite."
          }
        },
        "it" : {
          "stringUnit" : {
