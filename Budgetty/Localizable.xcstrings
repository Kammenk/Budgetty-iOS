    "This shapes your Insights — change anytime." : {
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Това оформя вашия Анализ — сменете по всяко време."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tím se řídí vaše Přehledy — kdykoli to můžete změnit."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette former din Indsigt — du kan altid ændre det."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das prägt deine Einblicke — jederzeit änderbar."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto da forma a tus Análisis — cámbialo cuando quieras."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tämä muokkaa Analyysi-näkymääsi — voit muuttaa sitä milloin tahansa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela façonne tes Analyses — modifiable à tout moment."
          }
