    "Totals don't quite match — items add up to **%@**, the receipt shows **%@**. You can still save." : {
      "comment" : "A warning message that compares the subtotal of a receipt to a price anchor. The argument is the subtotal, the second argument is the price anchor.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "Totals don't quite match — items add up to **%1$@**, the receipt shows **%2$@**. You can still save."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сумите не съвпадат напълно — артикулите дават **%1$@**, бележката показва **%2$@**. Все пак можете да запазите."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Součty úplně nesedí — položky dávají **%1$@**, účtenka ukazuje **%2$@**. Přesto můžete uložit."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Totalerne passer ikke helt — varerne giver **%1$@**, kvitteringen viser **%2$@**. Du kan stadig gemme."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Summen passen nicht ganz — Artikel ergeben **%1$@**, der Beleg zeigt **%2$@**. Du kannst trotzdem speichern."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los totales no coinciden del todo: los artículos suman **%1$@** y el recibo muestra **%2$@**. Aún puedes guardar."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Summat eivät aivan täsmää — tuotteet ovat **%1$@**, kuitti näyttää **%2$@**. Voit silti tallentaa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les totaux ne correspondent pas tout à fait — les articles font **%1$@**, le reçu indique **%2$@**. Vous pouvez quand même enregistrer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I totali non coincidono del tutto — gli articoli fanno **%1$@**, lo scontrino mostra **%2$@**. Puoi comunque salvare."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Totalene stemmer ikke helt — varene blir **%1$@**, kvitteringen viser **%2$@**. Du kan lagre likevel."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De totalen kloppen niet helemaal — de artikelen zijn **%1$@**, de bon toont **%2$@**. Je kunt toch opslaan."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sumy nie do końca się zgadzają — pozycje dają **%1$@**, paragon pokazuje **%2$@**. Nadal możesz zapisać."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os totais não coincidem bem — os artigos somam **%1$@**, o recibo mostra **%2$@**. Ainda podes guardar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Totalurile nu se potrivesc chiar — articolele dau **%1$@**, bonul arată **%2$@**. Poți salva oricum."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Суммы не совсем совпадают — товары дают **%1$@**, чек показывает **%2$@**. Можно всё равно сохранить."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Summorna stämmer inte riktigt — varorna blir **%1$@**, kvittot visar **%2$@**. Du kan spara ändå."
          }
        }
      }
    },
    "Touch & hold your Home Screen, tap ＋, and search “Budgetty” to add these." : {
      "comment" : "A description of how to add the widget to your home screen.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Задръжте върху началния екран, докоснете ＋ и потърсете „Budgetty“, за да ги добавите."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Podržte prst na ploše, klepněte na ＋ a vyhledejte „Budgetty“ pro přidání."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hold på hjemmeskærmen, tryk på ＋, og søg efter “Budgetty” for at tilføje dem."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halte den Home-Bildschirm gedrückt, tippe auf ＋ und suche „Budgetty“, um sie hinzuzufügen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantén pulsada la pantalla de inicio, toca ＋ y busca «Budgetty» para añadirlos."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Paina kotinäyttöä pitkään, napauta ＋ ja hae ”Budgetty” lisätäksesi ne."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Appuyez longuement sur l’écran d’accueil, touchez ＋ et cherchez « Budgetty » pour les ajouter."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tieni premuta la schermata Home, tocca ＋ e cerca “Budgetty” per aggiungerli."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hold inne på Hjem-skjermen, trykk ＋ og søk etter “Budgetty” for å legge dem til."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Houd het beginscherm ingedrukt, tik op ＋ en zoek “Budgetty” om ze toe te voegen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Przytrzymaj ekran główny, dotknij ＋ i wyszukaj „Budgetty”, aby je dodać."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mantém premido o ecrã principal, toca em ＋ e procura “Budgetty” para os adicionar."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ține apăsat pe ecranul principal, atinge ＋ și caută „Budgetty” pentru a le adăuga."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нажмите и удерживайте главный экран, коснитесь ＋ и найдите «Budgetty», чтобы добавить их."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Håll på hemskärmen, tryck på ＋ och sök efter “Budgetty” för att lägga till dem."
          }
        }
      }
