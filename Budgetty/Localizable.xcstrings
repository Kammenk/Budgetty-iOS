    "Tap Scan to add your first one" : {
      "comment" : "A description of how to add a receipt.",
      "isCommentAutoGenerated" : true
    },
    "Tap to show or hide a section. Use Edit to drag and reorder. Applies on iPhone." : {
      "comment" : "A description of the Home customization sheet.",
      "isCommentAutoGenerated" : true
    },
    "The items we read add up to %@, but the receipt subtotal is %@. Double-check the items before saving." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مجموع هذه العناصر %1$@، لكن الإيصال يعرض %2$@. تحقّق من أسعار العناصر قبل الحفظ."
          }
        },
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тези артикули дават общо %1$@, но бележката показва %2$@. Провери цените на артикулите преди да запазиш."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এই আইটেমগুলোর যোগফল %1$@, কিন্তু রসিদে %2$@ দেখাচ্ছে। সংরক্ষণের আগে আইটেমের দাম যাচাই করুন।"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Artikel ergeben %1$@, aber der Beleg zeigt %2$@. Überprüfe die Artikelpreise, bevor du speicherst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estos artículos suman %1$@, pero el recibo muestra %2$@. Comprueba los precios antes de guardar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ces articles totalisent %1$@, mais le reçu indique %2$@. Vérifiez les prix des articles avant d'enregistrer."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "इन वस्तुओं का योग %1$@ है, लेकिन रसीद %2$@ दिखाती है। सहेजने से पहले वस्तुओं की कीमतें जाँच लें।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Item-item ini berjumlah %1$@, tetapi struk menunjukkan %2$@. Periksa kembali harga item sebelum menyimpan."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questi articoli ammontano a %1$@, ma lo scontrino indica %2$@. Ricontrolla i prezzi degli articoli prima di salvare."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらの項目の合計は %1$@ ですが、レシートには %2$@ と表示されています。保存する前に項目の価格を確認してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 항목들의 합계는 %1$@이지만 영수증에는 %2$@로 표시됩니다. 저장하기 전에 항목 가격을 다시 확인하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deze items tellen op tot %1$@, maar de bon toont %2$@. Controleer de itemprijzen voordat je opslaat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te pozycje sumują się do %1$@, ale paragon pokazuje %2$@. Sprawdź ceny pozycji przed zapisaniem."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estes itens somam %1$@, mas o recibo mostra %2$@. Confira os preços dos itens antes de salvar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Эти позиции в сумме дают %1$@, но в чеке указано %2$@. Проверьте цены позиций перед сохранением."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bu ürünler toplam %1$@ ediyor, ancak fiş %2$@ gösteriyor. Kaydetmeden önce ürün fiyatlarını kontrol et."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ці позиції в сумі дають %1$@, але в чеку вказано %2$@. Перевірте ціни позицій перед збереженням."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ان اشیاء کا مجموعہ %1$@ ہے، لیکن رسید %2$@ دکھاتی ہے۔ محفوظ کرنے سے پہلے اشیاء کی قیمتیں دوبارہ جانچیں۔"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Các mục này cộng lại là %1$@, nhưng hóa đơn hiển thị %2$@. Hãy kiểm tra lại giá các mục trước khi lưu."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "这些项目合计 %1$@，但收据显示 %2$@。保存前请核对项目价格。"
          }
        }
      }
    },
