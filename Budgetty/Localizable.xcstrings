          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Napauta näyttääksesi tai piilottaaksesi osion. Järjestä uudelleen Muokkaa-toiminnolla. Koskee iPhonea."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez pour afficher ou masquer une section. Utilisez Modifier pour réorganiser. Sur iPhone."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tocca per mostrare o nascondere una sezione. Usa Modifica per riordinare. Vale su iPhone."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trykk for å vise eller skjule en seksjon. Bruk Rediger for å endre rekkefølge. Gjelder på iPhone."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tik om een sectie te tonen of verbergen. Gebruik Bewerken om te herordenen. Geldt op iPhone."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dotknij, aby pokazać lub ukryć sekcję. Użyj Edytuj, aby zmienić kolejność. Dotyczy iPhone’a."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca para mostrar ou ocultar uma secção. Usa Editar para reordenar. Aplica-se no iPhone."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atinge pentru a afișa sau ascunde o secțiune. Folosește Editare pentru reordonare. Se aplică pe iPhone."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Нажмите, чтобы показать или скрыть раздел. Используйте «Правку» для перестановки. Действует на iPhone."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tryck för att visa eller dölja en sektion. Använd Redigera för att ändra ordning. Gäller på iPhone."
          }
        }
      }
    },
    "The items we read add up to %@, but the receipt subtotal is %@. Double-check the items before saving." : {
      "localizations" : {
        "bg" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Тези артикули дават общо %1$@, но бележката показва %2$@. Провери цените на артикулите преди да запазиш."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Artikel ergeben %1$@, aber der Beleg zeigt %2$@. Überprüfe die Artikelpreise, bevor du speicherst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estos artículos suman %1$@, pero el recibo muestra %2$@. Comprueba los precios antes de guardar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ces articles totalisent %1$@, mais le reçu indique %2$@. Vérifiez les prix des articles avant d'enregistrer."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questi articoli ammontano a %1$@, ma lo scontrino indica %2$@. Ricontrolla i prezzi degli articoli prima di salvare."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deze items tellen op tot %1$@, maar de bon toont %2$@. Controleer de itemprijzen voordat je opslaat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te pozycje sumują się do %1$@, ale paragon pokazuje %2$@. Sprawdź ceny pozycji przed zapisaniem."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estes itens somam %1$@, mas o recibo mostra %2$@. Confira os preços dos itens antes de salvar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Эти позиции в сумме дают %1$@, но в чеке указано %2$@. Проверьте цены позиций перед сохранением."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Přečtené položky dávají dohromady %1$@, ale mezisoučet na účtence je %2$@. Před uložením položky zkontrolujte."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De varer, vi læste, giver i alt %1$@, men kvitteringens subtotal er %2$@. Tjek varerne, før du gemmer."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lukemamme tuotteet ovat yhteensä %1$@, mutta kuitin välisumma on %2$@. Tarkista tuotteet ennen tallennusta."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Varene vi leste, summerer til %1$@, men kvitteringens delsum er %2$@. Dobbeltsjekk varene før du lagrer."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Articolele citite însumează %1$@, dar subtotalul bonului este %2$@. Verifică articolele înainte de salvare."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Varorna vi läste summerar till %1$@, men kvittots delsumma är %2$@. Dubbelkolla varorna innan du sparar."
          }
        }
      }
    },
